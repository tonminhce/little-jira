// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom User model with soft delete and profile fields
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // Nullable for OAuth users
  deletedAt     DateTime? // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]

  // Team relations
  teamMemberships TeamMember[]
  teamActivities  TeamActivity[]  @relation("UserActivities")

  // Project relations
  ownedProjects    Project[]       @relation("ProjectOwner")
  projectFavorites ProjectFavorite[]

  // Issue relations
  ownedIssues          Issue[]        @relation("IssueOwner")
  assignedIssues       Issue[]        @relation("IssueAssignee")
  previouslyAssignedIssues Issue[]    @relation("IssuePreviousAssignee")
  issueHistory         IssueHistory[] @relation("IssueHistoryUser")
  comments             Comment[]      @relation("CommentAuthor")

  // Notification relations
  notifications         Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("NotificationActor")

  @@index([email])
  @@index([deletedAt])
}

// Team model with soft delete
model Team {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(50)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  members    TeamMember[]
  invites    TeamInvite[]
  activities TeamActivity[]
  projects   Project[]
  notifications Notification[]

  @@index([deletedAt])
}

// Team membership with role-based access
model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   // OWNER, ADMIN, MEMBER
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// Team invite with expiring token
model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
  @@index([token])
  @@index([email])
}

// Activity log for audit trail
model TeamActivity {
  id        String   @id @default(cuid())
  teamId    String
  type      String   // MEMBER_JOINED, MEMBER_LEFT, MEMBER_KICKED, ROLE_CHANGED, TEAM_CREATED, TEAM_UPDATED, TEAM_DELETED, INVITE_SENT, OWNERSHIP_TRANSFERRED
  userId    String?  // User who performed the action
  metadata  String?  @db.Text // JSON string for additional data
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation("UserActivities", fields: [userId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([createdAt])
}

// Project model with soft delete and archive
model Project {
  id          String    @id @default(cuid())
  teamId      String
  ownerId     String
  name        String    @db.VarChar(100)
  description String?   @db.Text
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team     Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner    User  @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  favorites ProjectFavorite[]
  issues    Issue[]
  labels    IssueLabel[]
  columns   ProjectColumn[]
  notifications Notification[]

  @@index([teamId])
  @@index([ownerId])
  @@index([deletedAt])
  @@index([archivedAt])
}

// Project custom columns for Kanban board
model ProjectColumn {
  id        String   @id @default(cuid())
  projectId String
  name      String   @db.VarChar(30)
  color     String   @db.VarChar(7) @default("#6B7280") // HEX color
  order     Int      @default(0)
  wipLimit  Int?     // Work In Progress limit (null = no limit)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@index([projectId])
  @@index([order])
}

// Project favorites (per-user)
model ProjectFavorite {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// Issue model with soft delete
model Issue {
  id                String    @id @default(cuid())
  projectId         String
  ownerId           String    // Creator (Reporter)
  assigneeId        String?   // Current assigned user
  previousAssigneeId String?  // Previous assignee (Defected Owner)
  columnId          String?   // Custom column (null = default status)
  title             String    @db.VarChar(200)
  description       String?   @db.Text
  status            String    @default("BACKLOG") // BACKLOG, IN_PROGRESS, DONE (fallback for default columns)
  priority          String    @default("MEDIUM")  // HIGH, MEDIUM, LOW
  dueDate           DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner            User    @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  assignee         User?   @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  previousAssignee User?   @relation("IssuePreviousAssignee", fields: [previousAssigneeId], references: [id], onDelete: SetNull)
  column           ProjectColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)

  labels   IssueAssignment[]
  history  IssueHistory[]
  comments Comment[]
  subtasks Subtask[]
  notifications Notification[]

  @@index([projectId])
  @@index([ownerId])
  @@index([assigneeId])
  @@index([previousAssigneeId])
  @@index([columnId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
  @@index([dueDate])
}

// Project-level labels
model IssueLabel {
  id        String @id @default(cuid())
  projectId String
  name      String @db.VarChar(30)
  color     String @db.VarChar(7) // HEX color

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  IssueAssignment[]

  @@unique([projectId, name])
  @@index([projectId])
}

// Many-to-many: Issue <-> Label
model IssueAssignment {
  id        String   @id @default(cuid())
  issueId   String
  labelId   String
  createdAt DateTime @default(now())

  issue Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label IssueLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([issueId, labelId])
  @@index([issueId])
  @@index([labelId])
}

// Issue change history
model IssueHistory {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  field     String   // status, assigneeId, priority, title, dueDate
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation("IssueHistoryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([createdAt])
}

// Issue comments
model Comment {
  id        String    @id @default(cuid())
  issueId   String
  userId    String
  body      String    @db.Text
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([createdAt])
  @@index([deletedAt])
}

// Issue subtasks
model Subtask {
  id        String   @id @default(cuid())
  issueId   String
  title     String   @db.VarChar(200)
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([order])
}

// User notifications
model Notification {
  id        String   @id @default(cuid())
  userId    String   // Recipient
  type      String   // ISSUE_ASSIGNED, ISSUE_UPDATED, COMMENT_ADDED, DUE_DATE_REMINDER, ISSUE_MENTIONED
  title     String   @db.VarChar(200)
  body      String?  @db.Text
  read      Boolean  @default(false)
  // Related entities
  issueId   String?
  projectId String?
  teamId    String?
  actorId   String?  // Who triggered the notification
  createdAt DateTime @default(now())

  user    User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  issue   Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([type])
}
